---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle';
import '../styles/global.css';
---

<Layout title="About — Joyce Doan" description="UI/UX designer focused on data-driven products, dashboards, and complex interfaces.">

  <header style="position: sticky; top: 0; z-index: 50; background: color-mix(in srgb, var(--bg-page) 88%, transparent); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border-bottom: 1px solid var(--border-subtle);">
    <div style="max-width: 1320px; margin: 0 auto; padding: 0 48px; height: 48px; display: flex; align-items: center; justify-content: space-between;">
      <a href="/" style="display: inline-flex; align-items: center; gap: 8px; text-decoration: none;">
        <img src="/logo.svg" alt="Joyce Doan" height="18" style="display: block; filter: var(--logo-filter);" />
        <span style="font: 400 12px/16px 'JetBrains Mono', monospace; color: var(--text-disabled);">/</span>
        <span style="font: 400 13px/20px 'Poppins', sans-serif; color: var(--text-secondary);">About</span>
      </a>
      <div style="display: flex; align-items: center; gap: 24px;">
        <a href="/work" style="font: 500 13px/20px 'Poppins', sans-serif; color: var(--text-secondary); text-decoration: none;">Work</a>
        <a href="/writing" style="font: 500 13px/20px 'Poppins', sans-serif; color: var(--text-secondary); text-decoration: none;">Writing</a>
        <a href="/contact" style="font: 500 13px/20px 'Poppins', sans-serif; color: var(--text-secondary); text-decoration: none;">Contact</a>
        <ThemeToggle client:load />
      </div>
    </div>
  </header>

  <!-- ── Intro ── -->
  <section style="border-bottom: 1px solid var(--border-subtle);">
    <div style="max-width: 1320px; margin: 0 auto; padding: 72px 48px 56px;">
      <div class="overline" style="margin-bottom: 16px;">UI/UX Designer · Consortia Group</div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: flex-start;">
        <h1 style="font: 500 clamp(36px, 5vw, 64px)/1.05 'Poppins', sans-serif; letter-spacing: -0.04em; color: var(--text-bright); margin: 0;">
          I design tools that respect their users' time and intelligence.
        </h1>
        <div style="display: flex; flex-direction: column; gap: 20px; padding-top: 8px;">
          <p style="font: 400 16px/26px 'Poppins', sans-serif; color: var(--text-primary); margin: 0;">
            I'm a UI/UX designer focused on data-driven products — dashboards, internal tools, and complex interfaces where clarity matters more than decoration.
          </p>
          <p style="font: 400 16px/26px 'Poppins', sans-serif; color: var(--text-primary); margin: 0;">
            Currently exploring the intersection of AI, UX, and product design — figuring out how non-deterministic outputs can feel trustworthy in high-stakes workflows.
          </p>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0; margin-top: 8px; font: 500 13px/20px 'JetBrains Mono', monospace;">
            {[
              ['Currently', 'Senior UI/UX Designer, Consortia Group'],
              ['Based', 'San Francisco / Remote'],
              ['Tools', 'Figma · AI Tools · Notion'],
              ['Open to', 'Senior / Staff IC roles'],
            ].map(([k, v]) => (
              <div style="padding: 12px 0; border-bottom: 1px solid var(--border-subtle);">
                <div style="color: var(--text-secondary); margin-bottom: 2px;">{k}</div>
                <div style="color: var(--text-bright);">{v}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Experience ── -->
  <section style="border-bottom: 1px solid var(--border-subtle);">
    <div style="max-width: 1320px; margin: 0 auto; padding: 96px 48px;">
      <div class="overline" style="margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid var(--border-subtle);">Experience</div>
      <h2 style="font: 500 64px/0.96 'Poppins', sans-serif; letter-spacing: -0.03em; color: var(--text-bright); margin: 0 0 64px;">My Journey</h2>

      <div style="display: grid; grid-template-columns: 260px 1fr; border-top: 1px solid var(--border-subtle);">
        <!-- Timeline -->
        <div style="border-right: 1px solid var(--border-subtle); padding-top: 40px; padding-right: 40px;">
          <div class="timeline-entry timeline-active" data-job="1" style="padding-bottom: 32px; cursor: pointer;">
            <div style="font: 500 14px/20px 'Poppins', sans-serif; color: var(--text-bright); margin-bottom: 4px;">Jul 2023 – Present</div>
            <div style="font: 400 13px/18px 'Poppins', sans-serif; color: var(--text-secondary);">2 yrs 6 mos</div>
          </div>
          <div style="border-top: 1px solid var(--border-subtle);"></div>
          <div class="timeline-entry" data-job="2" style="padding-top: 24px; cursor: pointer;">
            <div style="font: 500 14px/20px 'Poppins', sans-serif; color: var(--text-secondary); margin-bottom: 4px;">Mar 2023 – Jun 2023</div>
            <div style="font: 400 13px/18px 'Poppins', sans-serif; color: var(--text-disabled);">4 mos</div>
          </div>
        </div>

        <!-- Detail -->
        <div style="padding: 40px 0 0 56px;">
          <div id="job-1">
            <h3 style="font: 600 28px/1.2 'Poppins', sans-serif; letter-spacing: -0.02em; color: var(--text-bright); margin: 0 0 8px;">UI/UX Designer</h3>
            <div style="font: 400 14px/20px 'Poppins', sans-serif; color: var(--text-secondary); margin-bottom: 28px;">Consortia Group &nbsp;·&nbsp; United States – Vietnam</div>
            <p style="font: 400 16px/26px 'Poppins', sans-serif; color: var(--text-primary); margin: 0 0 16px; max-width: 640px;">
              I work across multiple product teams to design websites, brand identities, internal tools, and scalable design systems.
            </p>
            <p style="font: 400 16px/26px 'Poppins', sans-serif; color: var(--text-primary); margin: 0 0 28px; max-width: 640px;">
              My responsibilities include wireframing, user flow mapping, high-fidelity UI design, interaction design, documenting components for developers, and performing testing after deployment to ensure the product functions correctly and matches the intended design.
            </p>
            <div style="font: 600 14px/20px 'Poppins', sans-serif; color: var(--text-bright); margin-bottom: 14px;">Key Accomplishments</div>
            <ul style="font: 400 15px/26px 'Poppins', sans-serif; color: var(--text-primary); margin: 0; padding-left: 20px; display: flex; flex-direction: column; gap: 10px; max-width: 640px;">
              <li>Designed 10+ projects spanning websites, dashboards, and product interfaces across banking, AI-driven marketing, hospitality, and digital education.</li>
              <li>Used AI tools to speed up ideation, content generation, layout exploration, and component documentation.</li>
              <li>Built consistent and scalable design systems adopted across multiple products.</li>
              <li>Communicated effectively with developers through shared understanding of component behavior and system constraints.</li>
            </ul>
          </div>
          <div id="job-2" style="display: none;">
            <h3 style="font: 600 28px/1.2 'Poppins', sans-serif; letter-spacing: -0.02em; color: var(--text-bright); margin: 0 0 8px;">UI/UX Designer</h3>
            <div style="font: 400 14px/20px 'Poppins', sans-serif; color: var(--text-secondary); margin-bottom: 28px;">Freelance &nbsp;·&nbsp; Remote</div>
            <p style="font: 400 16px/26px 'Poppins', sans-serif; color: var(--text-primary); margin: 0 0 16px; max-width: 640px;">
              Worked on short-term freelance engagements delivering UI designs, wireframes, and design system components for early-stage products.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Design Philosophy ── -->
  <section style="border-bottom: 1px solid var(--border-subtle);">
    <div style="max-width: 1320px; margin: 0 auto; padding: 96px 48px;">
      <div class="overline" style="margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid var(--border-subtle);">How I work</div>
      <h2 style="font: 500 64px/0.96 'Poppins', sans-serif; letter-spacing: -0.03em; color: var(--text-bright); margin: 0 0 64px;">Design philosophy.</h2>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0;">
        {[
          {
            n: '01',
            title: 'Clarity over cleverness',
            body: 'The best interface is the one that disappears. If a user has to think about how to use it, the design has already failed. I cut features before adding them.',
          },
          {
            n: '02',
            title: 'Design from the decision, not the data',
            body: 'Dashboards and tools exist to support a specific decision. I start there — what question is someone trying to answer? — and work backward to the UI.',
          },
          {
            n: '03',
            title: 'Systems thinking, always',
            body: 'A component is not done until it exists in context. I design tokens, patterns, and constraints so teams can build consistently without asking me every time.',
          },
        ].map((p, i) => (
          <div style={`padding: 32px ${i < 2 ? '40px 32px 0' : '0 32px 0'}; border-left: ${i > 0 ? '1px solid var(--border-subtle)' : 'none'};`}>
            <div style="font: 500 11px/16px 'JetBrains Mono', monospace; color: var(--text-disabled); margin-bottom: 16px;">{p.n}</div>
            <h3 style="font: 500 18px/1.3 'Poppins', sans-serif; letter-spacing: -0.01em; color: var(--text-bright); margin: 0 0 12px;">{p.title}</h3>
            <p style="font: 400 15px/26px 'Poppins', sans-serif; color: var(--text-secondary); margin: 0;">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Skills ── -->
  <section style="border-bottom: 1px solid var(--border-subtle);">
    <div style="max-width: 1320px; margin: 0 auto; padding: 96px 48px;">
      <div class="overline" style="margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid var(--border-subtle);">Capabilities</div>
      <h2 style="font: 500 64px/0.96 'Poppins', sans-serif; letter-spacing: -0.03em; color: var(--text-bright); margin: 0 0 64px;">Design skills.</h2>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 48px 80px;">
        {[
          { label: 'UI Design',       tags: ['Interface Design', 'Visual Hierarchy', 'Color Theory', 'Typography'] },
          { label: 'Design Systems',  tags: ['Component Libraries', 'Style Guides', 'Documentation', 'Pattern Libraries'] },
          { label: 'UX Design',       tags: ['User Research', 'Usability Testing', 'Information Architecture', 'Wireframing'] },
          { label: 'Soft Skills',     tags: ['Communication', 'Problem Solving', 'Collaboration', 'Time Management'] },
          { label: 'Prototyping',     tags: ['Interactive Prototypes', 'User Flows', 'Animation', 'Micro-interactions'] },
          { label: 'Tools',           tags: ['Figma', 'AI Design Tools', 'Adobe Illustrator', 'Adobe Photoshop'] },
        ].map((group) => (
          <div>
            <div class="overline" style="margin-bottom: 14px;">{group.label}</div>
            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
              {group.tags.map((tag) => (
                <span style="display: inline-block; padding: 5px 14px; border: 1px solid var(--border-subtle); border-radius: var(--radius-full); font: 400 13px/20px 'Poppins', sans-serif; color: var(--text-secondary);">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Currently ── -->
  <section>
    <div style="max-width: 1320px; margin: 0 auto; padding: 96px 48px;">
      <div class="overline" style="margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid var(--border-subtle);">Right now</div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: flex-start;">
        <h2 style="font: 500 64px/0.96 'Poppins', sans-serif; letter-spacing: -0.03em; color: var(--text-bright); margin: 0;">What I'm exploring.</h2>
        <div style="display: flex; flex-direction: column; gap: 0;">
          {[
            ['AI × Design', 'How to expose design system context to AI coding tools so generated UI stays on-brand without manual correction.'],
            ['Data UX patterns', 'Researching dashboard interaction patterns that reduce cognitive load for analyst workflows.'],
            ['Design-to-code sync', 'Exploring tools and workflows that keep Figma and production code in sync — fewer handoff gaps, fewer surprises.'],
            ['Writing', 'Publishing short essays on product design thinking at the intersection of clarity, systems, and AI.'],
          ].map(([title, desc]) => (
            <div style="padding: 20px 0; border-bottom: 1px solid var(--border-subtle);">
              <div style="font: 500 14px/20px 'Poppins', sans-serif; color: var(--text-bright); margin-bottom: 4px;">{title}</div>
              <div style="font: 400 14px/22px 'Poppins', sans-serif; color: var(--text-secondary);">{desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  const entries = document.querySelectorAll<HTMLElement>('.timeline-entry');
  const jobs = [document.getElementById('job-1'), document.getElementById('job-2')];
  entries.forEach((entry) => {
    entry.addEventListener('click', () => {
      const jobId = entry.dataset.job;
      entries.forEach((e) => e.classList.remove('timeline-active'));
      entry.classList.add('timeline-active');
      jobs.forEach((j) => { if (j) j.style.display = j.id === `job-${jobId}` ? 'block' : 'none'; });
    });
  });
</script>

<style>
  .timeline-active > div:first-child { color: var(--text-bright) !important; }
  .timeline-entry:not(.timeline-active):hover > div:first-child { color: var(--text-primary) !important; }
</style>
