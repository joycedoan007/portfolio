---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle';
import '../styles/global.css';
import ContactCTA from '../components/ContactCTA.astro';
import Footer from '../components/Footer.astro';

const products = [
  {
    id: '01',
    name: 'UnifyDesign',
    company: 'UnifyDesign',
    category: 'Design Tooling · AI',
    year: '2025',
    tagline: 'The single source of truth for your design system.',
    description: 'A design system control plane that keeps Figma files, code repositories, and AI outputs in sync. Teams connect their sources — Figma, Git, Storybook, websites — and UnifyDesign detects when they\'ve drifted apart, then lets teams reconcile the differences from one workspace.',
    features: [
      { label: 'Overview', desc: 'Workspace health and sync summary at a glance' },
      { label: 'Drift Dashboard', desc: 'Detects where design/code has diverged with severity levels' },
      { label: 'Comparison', desc: 'Side-by-side token and component diffs with pull/push controls' },
      { label: 'Activity', desc: 'Audit log of every change and sync event' },
      { label: 'AI Tools', desc: 'Exposes live design system context to Claude, Cursor, and Windsurf via MCP' },
      { label: 'Team & Settings', desc: 'Members, integrations, and permission management' },
    ],
    url: '#',
    accent: 'green',
  },
  {
    id: '02',
    name: 'SocialCenter.ai',
    company: 'SocialCenter.ai',
    category: 'AI · Content · Marketing',
    year: '2024',
    tagline: 'From idea to published — one platform for all your social content.',
    description: 'An AI-powered social media and content management platform that lets users generate, schedule, approve, publish, and analyze content across social media and blog platforms from a single dashboard.',
    features: [
      { label: 'AI Content Generation', desc: 'Platform-native drafts for LinkedIn, X, Instagram, Facebook' },
      { label: 'Content Calendar', desc: 'FullCalendar-based scheduler with approval workflows and post queues' },
      { label: 'Approval Chains', desc: 'Single and multi-stage workflows with deadline enforcement' },
      { label: 'Engagement Engine', desc: 'Monitors comments/DMs, suggests replies, automation rules' },
      { label: 'Image Generation', desc: 'DALL-E, Vertex AI, and Stable Diffusion via pluggable provider registry' },
      { label: 'Brand Voice Cloning', desc: 'Learns writing style from past posts and applies it to new content' },
      { label: 'Agency Management', desc: 'Multi-tenant model with client sub-accounts and consolidated billing' },
    ],
    url: '#',
    accent: 'blue',
  },
  {
    id: '03',
    name: 'Marketing Center',
    company: 'Marketing Center',
    category: 'Marketing · Multi-channel',
    year: '2023',
    tagline: 'Every marketing channel. One coherent platform.',
    description: 'A multi-channel marketing platform with modules for SMS campaigns, landing pages, pop-ups, vouchers, display ads, and AI-generated content. Built a cohesive design system and improved UX across all key flows.',
    features: [
      { label: 'SMS Campaigns', desc: 'End-to-end campaign builder with audience segmentation' },
      { label: 'Landing Pages', desc: 'Drag-and-drop page builder with template library' },
      { label: 'Pop-ups & Vouchers', desc: 'Triggered overlays and discount code management' },
      { label: 'Display Ads', desc: 'Creative management and placement controls' },
      { label: 'AI Content', desc: 'AI-assisted copy generation across all channel types' },
      { label: 'Design System', desc: 'Cohesive component library adopted across all modules' },
    ],
    url: '#',
    accent: 'gray',
  },
];
---

<Layout title="Ventures — Joyce Doan" description="Products I helped design across three companies — UnifyDesign, SocialCenter.ai, and Marketing Center.">

  <header style="position: sticky; top: 0; z-index: 50; background: color-mix(in srgb, var(--bg-page) 88%, transparent); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border-bottom: 1px solid var(--border-subtle);">
    <div style="max-width: 1320px; margin: 0 auto; padding: 0 48px; height: 48px; display: flex; align-items: center; justify-content: space-between;">
      <a href="/" style="display: inline-flex; align-items: center; gap: 8px; text-decoration: none;">
        <img src="/logo.svg" alt="Joyce Doan" height="18" style="display: block; filter: var(--logo-filter);" />
        <span style="font: 400 12px/16px 'JetBrains Mono', monospace; color: var(--text-disabled);">/</span>
        <span style="font: 400 13px/20px 'Poppins', sans-serif; color: var(--text-secondary);">Ventures</span>
      </a>
      <div style="display: flex; align-items: center; gap: 24px;">
        <a href="/work" style="font: 500 13px/20px 'Poppins', sans-serif; color: var(--text-secondary); text-decoration: none;">Work</a>
        <a href="/writing" style="font: 500 13px/20px 'Poppins', sans-serif; color: var(--text-secondary); text-decoration: none;">Writing</a>
        <a href="/contact" style="font: 500 13px/20px 'Poppins', sans-serif; color: var(--text-secondary); text-decoration: none;">Contact</a>
        <ThemeToggle client:load />
      </div>
    </div>
  </header>

  <!-- Hero -->
  <div style="max-width: 1320px; margin: 0 auto; padding: 72px 48px 56px; border-bottom: 1px solid var(--border-subtle);">
    <div class="overline" style="margin-bottom: 16px;">3 ventures · 3 companies</div>
    <h1 style="font: 500 clamp(36px, 5vw, 64px)/1.05 'Poppins', sans-serif; letter-spacing: -0.04em; color: var(--text-bright); margin: 0 0 20px; max-width: 700px;">
      Side ventures.
    </h1>
    <p style="font: 400 16px/26px 'Poppins', sans-serif; color: var(--text-secondary); margin: 0; max-width: 480px;">
      Design work across three separate companies — spanning AI tooling, social media automation, and multi-channel marketing.
    </p>
  </div>

  <!-- Product list -->
  <div style="max-width: 1320px; margin: 0 auto; padding: 0 48px 120px;">
    {products.map((p, i) => (
      <div style={`padding: 72px 0; ${i < products.length - 1 ? 'border-bottom: 1px solid var(--border-subtle);' : ''}`}>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: flex-start;">

          <!-- Left: identity -->
          <div>
            <div style="display: flex; align-items: baseline; gap: 16px; margin-bottom: 20px;">
              <span style="font: 500 11px/16px 'JetBrains Mono', monospace; color: var(--text-disabled);">{p.id}</span>
              <span style="font: 500 11px/16px 'JetBrains Mono', monospace; color: var(--text-secondary); letter-spacing: 0.06em; text-transform: uppercase;">{p.category}</span>
              <span style="font: 500 11px/16px 'JetBrains Mono', monospace; color: var(--text-disabled); margin-left: auto;">{p.year}</span>
            </div>
            <div style="font: 500 11px/16px 'JetBrains Mono', monospace; color: var(--text-disabled); letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 12px;">
              {p.company}
            </div>
            <h2 style="font: 500 clamp(32px, 3.5vw, 48px)/1.05 'Poppins', sans-serif; letter-spacing: -0.03em; color: var(--text-bright); margin: 0 0 16px;">
              {p.name}
            </h2>
            <p style="font: 400 15px/24px 'Poppins', sans-serif; color: var(--text-secondary); margin: 0 0 24px; font-style: italic;">
              {p.tagline}
            </p>
            <a
              href={p.url}
              target={p.url !== '#' ? '_blank' : undefined}
              rel="noopener"
              style={`display: inline-flex; align-items: center; gap: 8px; height: 44px; padding: 10px 16px; margin-bottom: 32px; border-radius: var(--radius-md); font: 600 14px/20px 'Poppins', sans-serif; text-decoration: none; transition: opacity 150ms ease; background: var(--primary-700); color: var(--text-inverse); ${p.url === '#' ? 'opacity: 0.4; cursor: not-allowed; pointer-events: none;' : ''}`}
            >
              Visit {p.name}
              <i class="ph-bold ph-arrow-up-right" style="font-size: 13px;"></i>
            </a>
            <p style="font: 400 15px/26px 'Poppins', sans-serif; color: var(--text-primary); margin: 0 0 32px;">
              {p.description}
            </p>

          </div>

          <!-- Right: features -->
          <div>
            <div class="overline" style="margin-bottom: 16px;">Key features</div>
            <div style="display: flex; flex-direction: column; gap: 0;">
              {p.features.map((f) => (
                <div style="display: grid; grid-template-columns: 160px 1fr; gap: 16px; padding: 14px 0; border-bottom: 1px solid var(--border-subtle);">
                  <span style="font: 500 13px/20px 'Poppins', sans-serif; color: var(--text-bright);">{f.label}</span>
                  <span style="font: 400 13px/20px 'Poppins', sans-serif; color: var(--text-secondary);">{f.desc}</span>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    ))}
  </div>

  <ContactCTA />
  <Footer />
</Layout>
