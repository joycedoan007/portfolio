---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ThemeToggle from '../../components/ThemeToggle';

export async function getStaticPaths() {
  const entries = await getCollection('writing');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

const allEntries = await getCollection('writing');
const sorted = allEntries.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const h2s = headings.filter((h) => h.depth === 2);

function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
---

<Layout title={`${entry.data.title} — Joyce Doan`} description={entry.data.description}>
  <!-- ── Writing header ── -->
  <header
    style="position: sticky; top: 0; z-index: 50; background: color-mix(in srgb, var(--bg-page) 88%, transparent); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border-bottom: 1px solid var(--border-subtle);"
  >
    <div
      style="max-width: 100%; padding: 0 24px; height: 48px; display: flex; align-items: center; justify-content: space-between; gap: 24px;"
    >
      <a
        href="/"
        style="display: inline-flex; align-items: center; gap: 10px; text-decoration: none; flex-shrink: 0;"
      >
        <img src="/logo.svg" alt="Joyce Doan" height="18" style="display: block; filter: var(--logo-filter);" />
        <span style="font: 400 12px/16px 'JetBrains Mono', monospace; color: var(--text-disabled);">/</span>
        <span style="font: 400 13px/20px 'Poppins', sans-serif; color: var(--text-secondary);">Writing</span>
      </a>
      <ThemeToggle client:load />
    </div>
  </header>

  <!-- ── Three-column layout ── -->
  <div style="display: grid; grid-template-columns: 220px 1fr 200px; min-height: calc(100vh - 48px);">

    <!-- LEFT SIDEBAR -->
    <aside
      style="position: sticky; top: 48px; height: calc(100vh - 48px); overflow-y: auto; border-right: 1px solid var(--border-subtle); padding: 32px 0;"
    >
      <!-- Back to home -->
      <div style="padding: 0 20px 24px;">
        <a
          href="/"
          style="display: inline-flex; align-items: center; gap: 6px; text-decoration: none; color: var(--text-secondary); font: 500 12px/16px 'JetBrains Mono', monospace; transition: color 150ms ease;"
          class="sidebar-back"
        >
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" style="flex-shrink:0;">
            <path d="M8 2L4 6l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Portfolio
        </a>
      </div>

      <!-- Section label -->
      <div
        style="padding: 0 20px 12px; font: 500 11px/16px 'JetBrains Mono', monospace; color: var(--text-disabled); letter-spacing: 0.08em; text-transform: uppercase;"
      >
        Writing
      </div>

      <!-- Article list -->
      <nav>
        {
          sorted.map((e) => {
            const isActive = e.slug === entry.slug;
            return (
              <a
                href={`/writing/${e.slug}`}
                style={`
                  display: block;
                  padding: 8px 20px;
                  text-decoration: none;
                  border-left: 2px solid ${isActive ? 'var(--primary-500)' : 'transparent'};
                  background: ${isActive ? 'var(--bg-surface)' : 'transparent'};
                  transition: background 150ms ease;
                `}
                class={isActive ? '' : 'sidebar-link'}
              >
                <div
                  style={`font: ${isActive ? '500' : '400'} 13px/18px 'Poppins', sans-serif; color: ${isActive ? 'var(--text-bright)' : 'var(--text-secondary)'}; margin-bottom: 2px; transition: color 150ms ease;`}
                >
                  {e.data.title}
                </div>
                <div style="font: 400 11px/16px 'JetBrains Mono', monospace; color: var(--text-disabled);">
                  {fmtDate(e.data.date)} · {e.data.readTime}
                </div>
              </a>
            );
          })
        }
      </nav>
    </aside>

    <!-- MAIN CONTENT -->
    <main style="min-width: 0; padding: 56px 72px 120px;">
      <div class="overline" style="margin-bottom: 16px;">
        {fmtDate(entry.data.date)} · {entry.data.readTime}
      </div>
      <h1
        style="font: 600 40px/1.1 'Poppins', sans-serif; letter-spacing: -0.03em; color: var(--text-bright); margin: 0 0 16px; max-width: 680px;"
      >
        {entry.data.title}
      </h1>
      <p
        style="font: 400 16px/26px 'Poppins', sans-serif; color: var(--text-secondary); margin: 0 0 56px; max-width: 580px; border-bottom: 1px solid var(--border-subtle); padding-bottom: 40px;"
      >
        {entry.data.description}
      </p>

      <div class="prose">
        <Content />
      </div>

      <!-- Footer: Notion link -->
      <div
        style="margin-top: 80px; padding-top: 32px; border-top: 1px solid var(--border-subtle); display: flex; align-items: center; gap: 12px;"
      >
        <a
          href={entry.data.notionUrl}
          target="_blank"
          rel="noopener"
          style="display: inline-flex; align-items: center; gap: 8px; padding: 10px 16px; border-radius: var(--radius-full); border: 1px solid var(--border-subtle); background: var(--bg-surface); color: var(--text-bright); text-decoration: none; font: 500 13px/20px 'Poppins', sans-serif; transition: border-color 150ms ease;"
        >
          <i class="ph ph-notion-logo" style="font-size: 16px;"></i>
          Read on Notion
          <i class="ph-bold ph-arrow-up-right" style="font-size: 12px;"></i>
        </a>
        <a
          href="/"
          style="display: inline-flex; align-items: center; gap: 8px; padding: 10px 16px; border-radius: var(--radius-full); border: 1px solid var(--border-subtle); color: var(--text-secondary); text-decoration: none; font: 500 13px/20px 'Poppins', sans-serif; transition: color 150ms ease;"
        >
          ← Back to portfolio
        </a>
      </div>
    </main>

    <!-- RIGHT TOC -->
    <aside
      style="position: sticky; top: 48px; height: fit-content; max-height: calc(100vh - 48px); overflow-y: auto; padding: 40px 24px; border-left: 1px solid var(--border-subtle);"
    >
      {
        h2s.length > 0 && (
          <>
            <div
              style="font: 500 11px/16px 'JetBrains Mono', monospace; color: var(--text-disabled); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px;"
            >
              On this page
            </div>
            <nav id="toc-nav">
              {h2s.map((h) => (
                <a
                  href={`#${h.slug}`}
                  data-toc={h.slug}
                  style="display: block; padding: 5px 0; font: 400 12px/18px 'Poppins', sans-serif; color: var(--text-secondary); text-decoration: none; border-left: 2px solid transparent; padding-left: 12px; margin-left: -12px; transition: color 150ms ease, border-color 150ms ease;"
                  class="toc-link"
                >
                  {h.text}
                </a>
              ))}
            </nav>
          </>
        )
      }
    </aside>
  </div>
</Layout>

<style is:global>
  /* ── Prose content ── */
  .prose {
    max-width: 660px;
    color: var(--text-primary);
    font: 400 17px/28px 'Poppins', sans-serif;
  }
  .prose h2 {
    font: 600 24px/1.2 'Poppins', sans-serif;
    letter-spacing: -0.02em;
    color: var(--text-bright);
    margin: 52px 0 16px;
    scroll-margin-top: 72px;
  }
  .prose h3 {
    font: 600 16px/1.3 'Poppins', sans-serif;
    letter-spacing: -0.01em;
    color: var(--text-bright);
    margin: 32px 0 10px;
    scroll-margin-top: 72px;
  }
  .prose p {
    margin: 0 0 20px;
  }
  .prose a {
    color: var(--text-accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--text-accent) 40%, transparent);
  }
  .prose a:hover {
    text-decoration-color: var(--text-accent);
  }
  .prose strong {
    font-weight: 600;
    color: var(--text-bright);
  }
  .prose em {
    font-style: italic;
  }
  .prose ul,
  .prose ol {
    margin: 0 0 20px;
    padding-left: 24px;
  }
  .prose li {
    margin-bottom: 6px;
  }
  .prose blockquote {
    margin: 28px 0;
    padding: 16px 20px;
    border-left: 3px solid var(--primary-500);
    background: var(--bg-surface);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
    color: var(--text-secondary);
  }
  .prose blockquote p {
    margin: 0;
  }
  .prose code {
    font: 400 14px/1 'JetBrains Mono', monospace;
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    color: var(--text-accent);
  }
  .prose pre {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: 20px 24px;
    overflow-x: auto;
    margin: 24px 0;
  }
  .prose pre code {
    background: none;
    border: none;
    padding: 0;
    color: var(--text-primary);
    font-size: 13px;
    line-height: 1.7;
  }
  .prose hr {
    border: none;
    border-top: 1px solid var(--border-subtle);
    margin: 40px 0;
  }

  /* ── Sidebar hover states ── */
  .sidebar-link:hover {
    background: var(--bg-surface) !important;
  }
  .sidebar-link:hover > div:first-child {
    color: var(--text-bright) !important;
  }
  .sidebar-back:hover {
    color: var(--text-primary) !important;
  }
  .toc-link:hover {
    color: var(--text-bright) !important;
  }
  .toc-link.active {
    color: var(--text-bright) !important;
    border-left-color: var(--primary-500) !important;
  }
</style>

<script>
  // TOC scrollspy
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc]');
  if (links.length) {
    const headingEls = Array.from(links).map((l) =>
      document.getElementById(l.dataset.toc!)
    ).filter(Boolean) as HTMLElement[];

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            links.forEach((l) => l.classList.remove('active'));
            const active = document.querySelector<HTMLAnchorElement>(
              `[data-toc="${e.target.id}"]`
            );
            active?.classList.add('active');
          }
        });
      },
      { rootMargin: '-20% 0px -70% 0px' }
    );
    headingEls.forEach((el) => io.observe(el));
  }
</script>
