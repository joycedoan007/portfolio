---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ThemeToggle from '../../components/ThemeToggle';
import ContactCTA from '../../components/ContactCTA.astro';
import WritingSidebar from '../../components/WritingSidebar.astro';

export async function getStaticPaths() {
  const entries = await getCollection('writing');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

const allEntries = await getCollection('writing');
const sorted = allEntries.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const idx = sorted.findIndex(e => e.slug === entry.slug);
const prev = idx < sorted.length - 1 ? sorted[idx + 1] : null;
const next = idx > 0 ? sorted[idx - 1] : null;

// Group articles by category, preserving insertion order
const categoryOrder: string[] = [];
const grouped: Record<string, typeof sorted> = {};
for (const e of sorted) {
  const cat = e.data.category ?? 'Other';
  if (!grouped[cat]) { grouped[cat] = []; categoryOrder.push(cat); }
  grouped[cat].push(e);
}
const h2s = headings.filter((h) => h.depth === 2);
const tocGroups = entry.data.tocGroups;
const headingMap = Object.fromEntries(h2s.map((h) => [h.slug, h.text]));

function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

const pageUrl = Astro.url.href;
const linkedinShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`;
const xShareUrl = `https://x.com/intent/tweet?text=${encodeURIComponent(entry.data.title)}&url=${encodeURIComponent(pageUrl)}&via=joycedoan007`;
---

<Layout title={`${entry.data.title} — Joyce Doan`} description={entry.data.description}>
  <!-- ── Writing header ── -->
  <header
    style="position: sticky; top: 0; z-index: 50; background: color-mix(in srgb, var(--bg-page) 88%, transparent); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border-bottom: 1px solid var(--border-subtle);"
  >
    <div
      style="max-width: 100%; padding: 0 24px; height: 48px; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 24px;"
    >
      <div style="display: inline-flex; align-items: center; gap: 10px; flex-shrink: 0;">
        <a href="/" style="display: inline-flex; text-decoration: none;">
          <img src={`${import.meta.env.BASE_URL}logo.svg`} alt="Joyce Doan" height="18" style="display: block; filter: var(--logo-filter);" />
        </a>
        <span style="font: 400 12px/16px 'JetBrains Mono', monospace; color: var(--text-disabled);">/</span>
        <a href="/writing" style="font: 400 13px/20px 'Poppins', sans-serif; color: var(--text-secondary); text-decoration: none;">Writing</a>
      </div>
      <nav style="display: flex; justify-self: center;">
        {[
          ['Work', '/work'],
          ['Ventures', '/ventures'],
          ['About', '/about'],
          ['Writing', '/writing'],
          ['Contact', '/contact'],
        ].map(([label, href]) => (
          <a
            href={href}
            style="padding: 6px 14px; font: 500 13px/20px 'Poppins', sans-serif; color: var(--text-primary); text-decoration: none;"
          >
            {label}
          </a>
        ))}
      </nav>
      <div style="display: flex; justify-content: flex-end;">
        <ThemeToggle client:load />
      </div>
    </div>
  </header>

  <!-- ── Three-column layout ── -->
  <div style="display: grid; grid-template-columns: 220px 1fr 200px; min-height: calc(100vh - 48px);">

    <WritingSidebar entries={sorted} activeSlug={entry.slug} />

    <!-- MAIN CONTENT -->
    <main style="min-width: 0; padding: 56px 72px 120px;">
      <div class="overline" style="margin-bottom: 16px;">
        {fmtDate(entry.data.date)} · {entry.data.readTime}
      </div>
      <h1
        style="font: 600 40px/1.1 'Poppins', sans-serif; letter-spacing: -0.03em; color: var(--text-bright); margin: 0 0 16px; max-width: 680px;"
      >
        {entry.data.title}
      </h1>
      <p
        style="font: 400 16px/26px 'Poppins', sans-serif; color: var(--text-secondary); margin: 0 0 56px; max-width: 580px; border-bottom: 1px solid var(--border-subtle); padding-bottom: 40px;"
      >
        {entry.data.description}
      </p>

      <div class="prose">
        <Content />
      </div>

      <!-- Share -->
      <div style="margin-top: 64px; padding-top: 40px; border-top: 1px solid var(--border-subtle);">
        <div class="overline" style="margin-bottom: 16px;">Share</div>
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
          <a
            href={linkedinShareUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="share-btn"
            aria-label="Share on LinkedIn"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
          <a
            href={xShareUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="share-btn"
            aria-label="Share on X"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
            </svg>
            X
          </a>
          <button
            id="share-instagram"
            class="share-btn"
            aria-label="Copy link to share on Instagram"
            data-url={pageUrl}
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
            <span id="ig-share-label">Instagram</span>
          </button>
        </div>
      </div>

      <!-- Prev / Next -->
      <div style="margin-top: 80px; padding-top: 32px; border-top: 1px solid var(--border-subtle); display: flex; gap: 16px;">
        {prev ? (
          <a href={`/writing/${prev.slug}`} style="display: flex; flex-direction: column; gap: 4px; padding: 16px 20px; border-radius: var(--radius-lg); border: 1px solid var(--border-subtle); background: var(--bg-surface); text-decoration: none; flex: 1; transition: border-color 150ms ease;" class="nav-link">
            <span style="font: 500 11px/16px 'JetBrains Mono', monospace; color: var(--text-disabled); text-transform: uppercase;">← Previous</span>
            <span style="font: 500 14px/20px 'Poppins', sans-serif; color: var(--text-bright);">{prev.data.title}</span>
          </a>
        ) : <div style="flex:1" />}
        {next ? (
          <a href={`/writing/${next.slug}`} style="display: flex; flex-direction: column; gap: 4px; padding: 16px 20px; border-radius: var(--radius-lg); border: 1px solid var(--border-subtle); background: var(--bg-surface); text-decoration: none; flex: 1; align-items: flex-end; transition: border-color 150ms ease;" class="nav-link">
            <span style="font: 500 11px/16px 'JetBrains Mono', monospace; color: var(--text-disabled); text-transform: uppercase;">Next →</span>
            <span style="font: 500 14px/20px 'Poppins', sans-serif; color: var(--text-bright);">{next.data.title}</span>
          </a>
        ) : <div style="flex:1" />}
      </div>
    </main>

    <!-- RIGHT TOC -->
    <aside style="border-left: 1px solid var(--border-subtle);">
      <div style="position: sticky; top: 48px; height: fit-content; max-height: calc(100vh - 48px); overflow-y: auto; padding: 40px 24px;">
      {
        h2s.length > 0 && (
          <>
            <div
              style="font: 500 11px/16px 'JetBrains Mono', monospace; color: var(--text-disabled); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px;"
            >
              On this page
            </div>
            <nav id="toc-nav">
              {tocGroups ? (
                tocGroups.map((group) => (
                  <div style="margin-bottom: 20px;">
                    <div style="font: 500 12px/16px 'Poppins', sans-serif; color: var(--text-primary); margin-bottom: 4px;">
                      {group.label}
                    </div>
                    {group.slugs.map((slug) => headingMap[slug] && (
                      <a
                        href={`#${slug}`}
                        data-toc={slug}
                        style="display: block; padding: 4px 0; font: 400 12px/18px 'Poppins', sans-serif; color: var(--text-secondary); text-decoration: none; border-left: 2px solid transparent; padding-left: 24px; margin-left: -24px; transition: color 150ms ease, border-color 150ms ease;"
                        class="toc-link"
                      >
                        {headingMap[slug]}
                      </a>
                    ))}
                  </div>
                ))
              ) : (
                h2s.map((h) => (
                  <a
                    href={`#${h.slug}`}
                    data-toc={h.slug}
                    style="display: block; padding: 5px 0; font: 400 12px/18px 'Poppins', sans-serif; color: var(--text-secondary); text-decoration: none; border-left: 2px solid transparent; padding-left: 24px; margin-left: -24px; transition: color 150ms ease, border-color 150ms ease;"
                    class="toc-link"
                  >
                    {h.text}
                  </a>
                ))
              )}
            </nav>
          </>
        )
      }
      </div>
    </aside>
  </div>
</Layout>

<style is:global>
  /* ── Prose content ── */
  .prose {
    max-width: 720px;
    color: var(--text-primary);
    font: 400 15px/24px 'Poppins', sans-serif;
  }
  .prose h2 {
    font: 600 24px/1.2 'Poppins', sans-serif;
    letter-spacing: -0.02em;
    color: var(--text-bright);
    margin: 52px 0 16px;
    scroll-margin-top: 72px;
  }
  .prose h3 {
    font: 600 16px/1.3 'Poppins', sans-serif;
    letter-spacing: -0.01em;
    color: var(--text-bright);
    margin: 32px 0 10px;
    scroll-margin-top: 72px;
  }
  .prose p {
    margin: 0 0 20px;
  }
  .prose a {
    color: var(--text-accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--text-accent) 40%, transparent);
  }
  .prose a:hover {
    text-decoration-color: var(--text-accent);
  }
  .prose strong {
    font-weight: 600;
    color: var(--text-bright);
  }
  .prose em {
    font-style: italic;
  }
  .prose ul,
  .prose ol {
    margin: 0 0 20px;
    padding-left: 24px;
  }
  .prose li {
    margin-bottom: 6px;
  }
  .prose blockquote {
    margin: 28px 0;
    padding: 16px 20px;
    border-left: 3px solid var(--primary-500);
    background: var(--bg-surface);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
    color: var(--text-secondary);
  }
  .prose blockquote p {
    margin: 0;
  }
  .prose code {
    font: 400 14px/1 'JetBrains Mono', monospace;
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    color: var(--text-accent);
  }
  .prose pre {
    background: #1a1d23;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-lg);
    padding: 20px 24px;
    overflow-x: auto;
    margin: 24px 0;
  }
  .prose pre code {
    background: none;
    border: none;
    padding: 0;
    color: #e2e4e9;
    font-size: 13px;
    line-height: 1.7;
  }
  [data-theme="light"] .prose pre {
    background: #f0ede8 !important;
    border: 1px solid var(--border-subtle);
  }
  [data-theme="light"] .prose pre code {
    color: #2c2c2e !important;
  }
  [data-theme="light"] .prose pre code span {
    color: #2c2c2e !important;
  }
  .prose hr {
    border: none;
    border-top: 1px solid var(--border-subtle);
    margin: 40px 0;
  }
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0 28px;
    font: 400 13px/20px 'JetBrains Mono', monospace;
  }
  .prose thead {
    border-bottom: 1px solid var(--border-default);
  }
  .prose th {
    padding: 8px 12px;
    text-align: left;
    font: 500 11px/16px 'JetBrains Mono', monospace;
    color: var(--text-disabled);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .prose td {
    padding: 10px 12px;
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-subtle);
    vertical-align: top;
  }
  .prose tr:last-child td {
    border-bottom: none;
  }
  .prose tbody tr:hover td {
    background: var(--bg-surface);
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 14px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-subtle);
    background: var(--bg-surface);
    color: var(--text-secondary);
    font: 500 13px/20px 'Poppins', sans-serif;
    text-decoration: none;
    cursor: pointer;
    transition: border-color 150ms ease, color 150ms ease;
  }
  .share-btn:hover {
    border-color: var(--border-default);
    color: var(--text-bright);
  }

  .nav-link:hover { border-color: var(--border-default) !important; }
  .toc-link:hover {
    color: var(--text-bright) !important;
  }
  .toc-link.active {
    color: var(--text-bright) !important;
    border-left-color: var(--primary-500) !important;
  }
</style>

<script>
  // Instagram — copy link to clipboard
  const igBtn = document.getElementById('share-instagram') as HTMLButtonElement | null;
  const igLabel = document.getElementById('ig-share-label');
  if (igBtn && igLabel) {
    igBtn.addEventListener('click', () => {
      const url = igBtn.dataset.url ?? location.href;
      navigator.clipboard.writeText(url).then(() => {
        igLabel.textContent = 'Copied!';
        igBtn.style.setProperty('color', 'var(--text-bright)');
        igBtn.style.setProperty('border-color', 'var(--border-default)');
        setTimeout(() => {
          igLabel.textContent = 'Instagram';
          igBtn.style.removeProperty('color');
          igBtn.style.removeProperty('border-color');
        }, 2000);
      });
    });
  }

  // TOC scrollspy
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc]');
  if (links.length) {
    const headingEls = Array.from(links).map((l) =>
      document.getElementById(l.dataset.toc!)
    ).filter(Boolean) as HTMLElement[];

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            links.forEach((l) => l.classList.remove('active'));
            const active = document.querySelector<HTMLAnchorElement>(
              `[data-toc="${e.target.id}"]`
            );
            active?.classList.add('active');
          }
        });
      },
      { rootMargin: '-20% 0px -70% 0px' }
    );
    headingEls.forEach((el) => io.observe(el));
  }
</script>
