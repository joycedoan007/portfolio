---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ThemeToggle from '../../components/ThemeToggle';
import WorkSidebar from '../../components/WorkSidebar.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

const all = await getCollection('work');
const sorted = all.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const recent = sorted.slice(0, 2);
const featured = sorted.filter(e => e.data.hasImage).slice(0, 3);
---

<Layout title="Work — Joyce Doan" description="Selected UI/UX design work by Joyce Doan.">

  <header style="position: sticky; top: 0; z-index: 50; background: color-mix(in srgb, var(--bg-page) 88%, transparent); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border-bottom: 1px solid var(--border-subtle);">
    <div style="max-width: 100%; padding: 0 24px; height: 48px; display: flex; align-items: center; justify-content: space-between; gap: 24px;">
      <div style="display: inline-flex; align-items: center; gap: 10px; flex-shrink: 0;">
        <a href="/" style="display: inline-flex; text-decoration: none;">
          <img src={`${import.meta.env.BASE_URL}logo.svg`} alt="Joyce Doan" height="18" style="display: block; filter: var(--logo-filter);" />
        </a>
        <span style="font: 400 12px/16px 'JetBrains Mono', monospace; color: var(--text-disabled);">/</span>
        <a href="/work" style="font: 500 13px/20px 'Poppins', sans-serif; color: var(--text-bright); text-decoration: none;">Work</a>
      </div>
      <ThemeToggle client:load />
    </div>
  </header>

  <div style="display: grid; grid-template-columns: 220px 1fr; min-height: calc(100vh - 48px);">

    <WorkSidebar entries={sorted} />

    <main style="min-width: 0;">

      <!-- Hero -->
      <div style="padding: 56px 72px 48px; border-bottom: 1px solid var(--border-subtle);">
        <div class="overline" style="margin-bottom: 16px;">UI/UX Designer · Consortia Group</div>
        <h1 style="font: 500 48px/1.0 'Poppins', sans-serif; letter-spacing: -0.04em; color: var(--text-bright); margin: 0 0 12px;">Work</h1>
        <p style="font: 400 15px/24px 'Poppins', sans-serif; color: var(--text-secondary); margin: 0; max-width: 480px;">
          Product UX and web design across analytics, AI, finance, and B2B SaaS.
        </p>
      </div>

      <div style="padding: 56px 72px 96px;">

        <!-- Featured -->
        <div style="margin-bottom: 56px;">
          <h2 style="font: 500 11px/16px 'JetBrains Mono', monospace; color: var(--text-secondary); letter-spacing: 0.08em; text-transform: uppercase; margin: 0 0 20px;">Featured</h2>
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
            {featured.map((e) => (
              <a href={`/work/${e.slug}`} class="work-card" style="display: flex; flex-direction: column; justify-content: space-between; border: 1px solid var(--border-subtle); border-radius: var(--radius-xl); background: var(--bg-surface); text-decoration: none; overflow: hidden; transition: border-color 150ms ease;">
                <div style="aspect-ratio: 16/9; overflow: hidden; background: var(--bg-elevated);">
                  <img src={`/work/${e.slug.replace(/^\d+-/, '')}/cover.png`} alt={e.data.title} style="width: 100%; height: 100%; object-fit: cover; display: block;" />
                </div>
                <div style="padding: 20px 24px; display: flex; flex-direction: column; gap: 24px; flex: 1; justify-content: space-between;">
                  <div>
                    <div class="overline" style="margin-bottom: 10px;">{e.data.subtitle}</div>
                    <h3 style="font: 500 15px/1.4 'Poppins', sans-serif; color: var(--text-bright); margin: 0 0 8px;">{e.data.title}</h3>
                    <p style="font: 400 13px/20px 'Poppins', sans-serif; color: var(--text-secondary); margin: 0;">{e.data.description}</p>
                  </div>
                  <div style="display: flex; align-items: center; justify-content: space-between;">
                    <span style="font: 400 11px/16px 'JetBrains Mono', monospace; color: var(--text-disabled);">{e.data.role} · {e.data.year}</span>
                    <i class="ph-bold ph-arrow-up-right" style="font-size: 13px; color: var(--text-disabled);"></i>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- All projects -->
        <div>
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
            <h2 style="font: 500 11px/16px 'JetBrains Mono', monospace; color: var(--text-secondary); letter-spacing: 0.08em; text-transform: uppercase; margin: 0;">All projects</h2>
            <div id="work-filters" style="display: flex; gap: 6px;">
              {['All', 'Product Design', 'Web Design', 'Branding'].map((cat) => (
                <button
                  data-filter={cat}
                  class="filter-btn"
                  style={`padding: 5px 12px; border-radius: var(--radius-full); border: 1px solid var(--border-subtle); background: ${cat === 'All' ? 'var(--primary-700)' : 'transparent'}; color: ${cat === 'All' ? 'var(--text-inverse)' : 'var(--text-secondary)'}; font: 500 11px/16px 'JetBrains Mono', monospace; letter-spacing: 0.04em; cursor: pointer; transition: all 150ms ease;`}
                >
                  {cat}
                </button>
              ))}
            </div>
          </div>
          <div id="project-list">
            {sorted.map((e, i) => (
              <a href={`/work/${e.slug}`} class="project-row" data-category={e.data.category ?? ''} style="display: grid; grid-template-columns: 32px 1fr 180px 80px; gap: 24px; align-items: center; padding: 16px 0; border-bottom: 1px solid var(--border-subtle); text-decoration: none; transition: padding 150ms ease;">
                <span style="font: 500 11px/16px 'JetBrains Mono', monospace; color: var(--text-disabled);">{String(i + 1).padStart(2, '0')}</span>
                <span style="font: 500 14px/20px 'Poppins', sans-serif; color: var(--text-bright);">{e.data.title}</span>
                <span style="font: 500 10px/16px 'JetBrains Mono', monospace; color: var(--text-secondary); letter-spacing: 0.06em; text-transform: uppercase;">{e.data.category ?? ''}</span>
                <span style="font: 400 11px/16px 'JetBrains Mono', monospace; color: var(--text-disabled); text-align: right;">{e.data.year}</span>
              </a>
            ))}
          </div>
        </div>

      </div>

      <ContactCTA />
      <Footer />
    </main>

  </div>

</Layout>

<style>
  .work-card:hover { border-color: var(--border-default) !important; }
  .work-card:hover i { color: var(--text-accent) !important; }
  .project-row:hover span:nth-child(2) { color: var(--text-accent) !important; }
  .filter-btn:hover { border-color: var(--border-default) !important; color: var(--text-bright) !important; }
  .filter-btn.active { background: var(--primary-700) !important; color: var(--text-inverse) !important; border-color: var(--primary-700) !important; }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const rows = document.querySelectorAll<HTMLElement>('.project-row');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'All';

      buttons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      rows.forEach((row) => {
        const cat = row.dataset.category ?? '';
        row.style.display = (filter === 'All' || cat === filter) ? 'grid' : 'none';
      });
    });
  });

  // Set "All" as active on load
  document.querySelector<HTMLButtonElement>('.filter-btn[data-filter="All"]')?.classList.add('active');
</script>
