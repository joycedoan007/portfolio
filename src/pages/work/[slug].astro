---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ThemeToggle from '../../components/ThemeToggle';
import ContactCTA from '../../components/ContactCTA.astro';
import Footer from '../../components/Footer.astro';
import WorkSidebar from '../../components/WorkSidebar.astro';

export async function getStaticPaths() {
  const entries = await getCollection('work');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const w = entry.data;

const all = await getCollection('work');
const sorted = all.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const idx = sorted.findIndex(e => e.slug === entry.slug);
const prev = idx > 0 ? sorted[idx - 1] : null;
const next = idx < sorted.length - 1 ? sorted[idx + 1] : null;
---

<Layout title={`${w.title} — Joyce Doan`} description={w.description}>
  <header style="position: sticky; top: 0; z-index: 50; background: color-mix(in srgb, var(--bg-page) 88%, transparent); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border-subtle);">
    <div style="max-width: 100%; padding: 0 24px; height: 48px; display: flex; align-items: center; justify-content: space-between;">
      <div style="display: inline-flex; align-items: center; gap: 10px; flex-shrink: 0;">
        <a href="/" style="display: inline-flex; text-decoration: none;">
          <img src="/logo.svg" alt="Joyce Doan" height="18" style="display: block; filter: var(--logo-filter);" />
        </a>
        <span style="font: 400 12px/16px 'JetBrains Mono', monospace; color: var(--text-disabled);">/</span>
        <a href="/work" style="font: 400 13px/20px 'Poppins', sans-serif; color: var(--text-secondary); text-decoration: none;">Work</a>
        <span style="font: 400 12px/16px 'JetBrains Mono', monospace; color: var(--text-disabled);">/</span>
        <span style="font: 500 13px/20px 'Poppins', sans-serif; color: var(--text-bright);">{w.title}</span>
      </div>
      <ThemeToggle client:load />
    </div>
  </header>

  <div style="display: grid; grid-template-columns: 220px 1fr 200px; min-height: calc(100vh - 48px);">
    <WorkSidebar entries={sorted} activeSlug={entry.slug} />

    <!-- Main -->
    <main style="min-width: 0; padding: 56px 72px 120px;">
      <div class="overline" style="margin-bottom: 16px;">{w.subtitle} · {w.role}</div>
      <h1 style="font: 700 clamp(28px, 4vw, 48px)/1.1 'Poppins', sans-serif; letter-spacing: -0.03em; color: var(--text-bright); margin: 0 0 20px; max-width: 640px;">{w.title}</h1>
      <p style="font: 400 16px/26px 'Poppins', sans-serif; color: var(--text-secondary); margin: 0 0 40px; max-width: 560px; padding-bottom: 40px; border-bottom: 1px solid var(--border-subtle);">{w.description}</p>

      <div style="display: flex; gap: 8px; margin-bottom: 48px; flex-wrap: wrap;">
        <span style="padding: 5px 14px; border-radius: var(--radius-full); border: 1px solid var(--border-default); font: 500 12px/18px 'Poppins', sans-serif; color: var(--text-secondary);">{w.role}</span>
        {w.skills.map(s => (
          <span style="padding: 5px 14px; border-radius: var(--radius-full); border: 1px solid var(--border-subtle); font: 500 11px/18px 'JetBrains Mono', monospace; color: var(--text-disabled);">{s}</span>
        ))}
      </div>

      <div class="prose"><Content /></div>

      <!-- Prev/Next -->
      <div style="margin-top: 80px; padding-top: 32px; border-top: 1px solid var(--border-subtle); display: flex; gap: 16px;">
        {prev ? (
          <a href={`/work/${prev.slug}`} style="display: flex; flex-direction: column; gap: 4px; padding: 16px 20px; border-radius: var(--radius-lg); border: 1px solid var(--border-subtle); text-decoration: none; background: var(--bg-surface); flex: 1;" class="nav-link">
            <span style="font: 500 11px/16px 'JetBrains Mono', monospace; color: var(--text-disabled); text-transform: uppercase;">← Previous</span>
            <span style="font: 500 13px/20px 'Poppins', sans-serif; color: var(--text-bright);">{prev.data.title}</span>
          </a>
        ) : <div style="flex:1"/>}
        {next ? (
          <a href={`/work/${next.slug}`} style="display: flex; flex-direction: column; gap: 4px; padding: 16px 20px; border-radius: var(--radius-lg); border: 1px solid var(--border-subtle); text-decoration: none; background: var(--bg-surface); flex: 1; align-items: flex-end;" class="nav-link">
            <span style="font: 500 11px/16px 'JetBrains Mono', monospace; color: var(--text-disabled); text-transform: uppercase;">Next →</span>
            <span style="font: 500 13px/20px 'Poppins', sans-serif; color: var(--text-bright);">{next.data.title}</span>
          </a>
        ) : <div style="flex:1"/>}
      </div>
    </main>

    <!-- Right sidebar -->
    <aside style="position: sticky; top: 48px; height: fit-content; padding: 40px 24px; border-left: 1px solid var(--border-subtle);">
      <div style="font: 500 11px/16px 'JetBrains Mono', monospace; color: var(--text-disabled); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px;">Skills</div>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        {w.skills.map(s => (
          <span style="font: 400 12px/18px 'JetBrains Mono', monospace; color: var(--text-secondary);">{s}</span>
        ))}
      </div>
    </aside>
  </div>
  <ContactCTA />
  <Footer />
</Layout>

<style is:global>
  .sidebar-link:hover { background: var(--bg-surface) !important; }
  .sidebar-back:hover { color: var(--text-primary) !important; }
  .nav-link:hover { border-color: var(--border-default) !important; }
  .prose p { font: 400 16px/28px 'Poppins', sans-serif; color: var(--text-primary); margin: 0 0 20px; }
  .prose h2 { font: 600 22px/1.2 'Poppins', sans-serif; letter-spacing: -0.02em; color: var(--text-bright); margin: 48px 0 16px; }
  .prose h3 { font: 600 16px/1.3 'Poppins', sans-serif; color: var(--text-bright); margin: 28px 0 10px; }
  .prose strong { font-weight: 600; color: var(--text-bright); }
  .prose ul { margin: 0 0 20px; padding-left: 20px; }
  .prose li { font: 400 15px/26px 'Poppins', sans-serif; color: var(--text-primary); margin-bottom: 6px; }
  .prose hr { border: none; border-top: 1px solid var(--border-subtle); margin: 40px 0; }
  .prose img { width: 100%; border-radius: var(--radius-lg); border: 1px solid var(--border-subtle); margin: 24px 0; display: block; }
</style>
