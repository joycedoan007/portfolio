---
const services = [
  {
    n: '01',
    title: 'Dashboard & data UX',
    body: "Hierarchies for dense data. Query-to-glance pipelines. Tables that don't make you squint.",
    tools: ['Figma', 'Charts', 'IA'],
  },
  {
    n: '02',
    title: 'Product UX & UI',
    body: 'End-to-end flows for B2B SaaS. Onboarding, settings, the unglamorous middle bits.',
    tools: ['Figma', 'Prototyping', 'Research'],
  },
  {
    n: '03',
    title: 'AI-integrated interfaces',
    body: 'Designing for non-deterministic outputs. Confidence, control, and graceful failure.',
    tools: ['GPT', 'Patterns', 'Prompts'],
  },
  {
    n: '04',
    title: 'Design systems',
    body: 'Tokens, components, contribution model. The kind that engineers actually use.',
    tools: ['Tokens', 'Figma', 'Docs'],
  },
];
---

<section id="services" style="border-bottom: 1px solid var(--border-subtle);">
  <div style="max-width: 1320px; margin: 0 auto; padding: 96px 48px;">
    <div
      data-reveal
      style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 48px; padding-bottom: 24px; border-bottom: 1px solid var(--border-subtle);"
    >
      <div>
        <div class="overline" style="margin-bottom: 12px;">04 · Services</div>
        <h2
          style="font: 500 64px/0.96 'Poppins', sans-serif; letter-spacing: -0.03em; color: var(--text-bright); margin: 0;"
        >
          What I do.
        </h2>
      </div>
      <p
        style="font: 400 15px/24px 'Poppins', sans-serif; color: var(--text-primary); max-width: 360px; margin: 0;"
      >
        Usually as a lead or solo designer on a small team. Occasionally as an advisor.
      </p>
    </div>

    {
      services.map((s, i) => (
        <div
          data-reveal
          style={`--reveal-delay: ${i * 50}ms; display: grid; grid-template-columns: 64px 320px 1fr 240px; gap: 32px; align-items: flex-start; padding: 36px 0; border-bottom: 1px solid var(--border-subtle);`}
        >
          <span
            style="font: 500 14px/18px 'JetBrains Mono', monospace; color: var(--text-secondary);"
          >
            {s.n}
          </span>
          <h3
            style="font: 500 36px/40px 'Poppins', sans-serif; letter-spacing: -0.02em; color: var(--text-bright); margin: 0;"
          >
            {s.title}
          </h3>
          <p
            style="font: 400 15px/24px 'Poppins', sans-serif; color: var(--text-primary); margin: 0; max-width: 460px;"
          >
            {s.body}
          </p>
          <div style="display: flex; gap: 8px; flex-wrap: wrap; justify-content: flex-end;">
            {s.tools.map((t) => (
              <span
                style="padding: 4px 10px; border: 1px solid var(--border-subtle); border-radius: var(--radius-full); font: 500 12px/16px 'JetBrains Mono', monospace; color: var(--text-primary);"
              >
                {t}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
