---
---
<section style="border-top: 1px solid var(--border-subtle);">
  <div style="max-width: 1320px; margin: 0 auto; padding: 96px 48px; display: flex; justify-content: space-between; align-items: center; gap: 48px;">
    <div>
      <div class="overline" style="margin-bottom: 16px;">Get in touch</div>
      <h2 style="font: 500 clamp(28px, 3.5vw, 48px)/1.05 'Poppins', sans-serif; letter-spacing: -0.03em; color: var(--text-bright); margin: 0; max-width: 560px;">
        Have a problem worth designing?
      </h2>
    </div>
    <a
      href="/contact"
      style="flex-shrink: 0; display: inline-flex; align-items: center; gap: 8px; height: 44px; padding: 10px 20px; border-radius: var(--radius-md); background: var(--primary-700); color: var(--text-inverse); font: 600 14px/20px 'Poppins', sans-serif; text-decoration: none; transition: opacity 150ms ease; white-space: nowrap;"
      class="cta-link"
    >
      Let's talk
      <i class="ph-bold ph-arrow-right" style="font-size: 13px;"></i>
    </a>
  </div>
</section>

<style>
  .cta-link:hover { opacity: 0.85; }
</style>
